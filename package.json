	"license": "MIT",
	"author": {
		"name": "Emil Bruckner",
		"email": "smart.gate5411@unemail.net"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/wizcut-app/n8n-nodes-wizcut.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
