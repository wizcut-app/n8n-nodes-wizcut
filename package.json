	"files": ["dist"],
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "^9.0.0",
		"prettier": "^3.0.0",
		"typescript": "^5.7.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
